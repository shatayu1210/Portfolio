# vLLM Configuration
VLLM_HOST=127.0.0.1
VLLM_PORT=8000
VLLM_TIMEOUT=90.0
VLLM_MODEL_PATH=/path/to/your/qwen-coder-finetuned

# RAG Configuration
CLEANSQL_RAG_TOPK=3
CLEANSQL_ENABLE_RERANKER=false
CLEANSQL_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
CLEANSQL_EMBED_MODEL=BAAI/bge-m3

# Self-Consistency Configuration
CLEANSQL_TEMP=0.2
CLEANSQL_SC_SAMPLES=3

# Qdrant Configuration
CLEANSQL_QDRANT_PREFIX=cleansql_user
