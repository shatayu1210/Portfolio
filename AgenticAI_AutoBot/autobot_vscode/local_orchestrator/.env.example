# ─────────────────────────────────────────────────────────────────────────────
# AutoBot Orchestrator — Environment Configuration
# Copy this file to .env and fill in your values.
# The .env file is git-ignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Backend (pick ONE, comment out the others) ───────────────────────────

# Option A: HuggingFace TGI — LoRA adapters (used in production)
# Deploy a TGI endpoint on HuggingFace Inference Endpoints, then fill in below.
AUTOBOT_MODE=hf_tgi
HF_TGI_ENDPOINT=https://your-tgi-endpoint.endpoints.huggingface.cloud
HF_TGI_TOKEN=hf_your_access_token_here
HF_PLANNER_ADAPTER=your-hf-username/autobot-planner-lora
HF_PATCHER_ADAPTER=your-hf-username/autobot-patcher-lora
# HF_CRITIC_ADAPTER=your-hf-username/autobot-critic-lora   # optional, shares patcher if unset

# Option B: Ollama (free, local, no tokens needed — good for development)
# Pull model first: ollama pull qwen2.5-coder:7b  then: ollama serve
# AUTOBOT_MODE=ollama
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5-coder:7b

# Option C: Google AI Studio (Gemini)
# Get a free API key at https://aistudio.google.com/apikey
# Free tier: 15 RPM / 1M TPM / 1500 req/day with gemini-2.0-flash-lite
# AUTOBOT_MODE=google_ai
# GOOGLE_API_KEY=your_google_api_key_here
# GEMINI_MODEL=gemini-2.5-flash-preview-04-17

# Option D: Vertex AI Gemini (GCP project)
# Requires: gcloud auth application-default login
# AUTOBOT_MODE=vertex
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_LOCATION=us-central1
# VERTEX_MODEL=gemini-2.5-flash

# ── GitHub (for live issue fetching) ─────────────────────────────────────────
# Generate at https://github.com/settings/tokens (public_repo scope is enough)
GITHUB_OWNER=apache
GITHUB_REPO=airflow
GITHUB_TOKEN=github_pat_your_token_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── Context / Token Limit Tuning ─────────────────────────────────────────────
# Total context window of the deployed model (input + output tokens combined).
# Used to warn when patcher_input approaches the limit.
# Match this to --max-total-tokens on your TGI server (default: 8192).
HF_TGI_MAX_CONTEXT_TOKENS=8192

# Max tokens the patcher model may generate in one call.
# Diffs can be long — increase this if you see output_truncated=true in logs.
# Typical unified diff for a 50-line change: ~400-600 tokens.
HF_TGI_PATCHER_MAX_NEW_TOKENS=2048

# ── Tree-sitter Symbol Index ──────────────────────────────────────────────────
# Path to the pre-built tree-sitter index JSON from the indexing pipeline.
# Build it with: python tree_sitter/build_treesitter_index.py --repo /path/to/airflow --output treesitter_index.json
# Then set this to the output path.
# Leave blank to disable symbol lookup (planner still works via grep).
TS_INDEX_PATH=tree_sitter/treesitter_index.json

# ── Pipeline Testing ──────────────────────────────────────────────────────────
# Stop the orchestrator early to inspect payloads without executing next steps.
# Options: "planner" (stops before patcher), "patcher" (stops before critic)
# Leave blank to run the full pipeline (planner → patcher → critic → sandbox).
AUTOBOT_STOP_AT=

# ── Neo4j / GraphRAG (similar-issue search + co-modified file suggestions) ───
# Spin up with: docker compose up neo4j  (see docker-compose.yml)
# Leave blank to disable GraphRAG (planner falls back to keyword search only).
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=your_neo4j_password_here

# ── Sandbox Validation ────────────────────────────────────────────────────────
# Directory inside the sandbox container where frontend commands (tsc, vitest) run.
# This is where package.json lives for the Airflow UI.
SANDBOX_UI_DIR=/opt/airflow/airflow-core/src/airflow/ui
